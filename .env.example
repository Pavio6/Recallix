# Server
SERVER_PORT=8081
GIN_MODE=debug

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=recallix
DB_PASSWORD=recallix
DB_NAME=recallix
DB_SSLMODE=disable

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT — 请替换为随机生成的 64 位十六进制字符串
JWT_SECRET=change-me
JWT_ACCESS_EXPIRE=6h
JWT_REFRESH_EXPIRE=720h

# Chat LLM — 对话模型
CHAT_MODEL=deepseek-v4-flash
CHAT_MODEL_BASE_URL=https://api.deepseek.com
CHAT_MODEL_API_KEY=sk-your-chat-api-key

# Agent LLM — Agent 推理模型
AGENT_MODEL=deepseek-v4-pro

# Embedding — embedding模型
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_API_KEY=sk-your-embedding-api-key
EMBEDDING_MODEL_DIMENSION=1024

# Rerank — 重排序模型
RERANK_MODEL=qwen3-rerank
RERANK_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
RERANK_MODEL_API_KEY=sk-your-rerank-api-key

# RAG 检索参数（可选，以下为默认值）
# RAG_TOP_K=5
# RAG_SCORE_THRESHOLD=0.45
# RAG_FALLBACK_MIN_SCORE=0
# RAG_THRESHOLD_DEGRADE_BY=0
# RAG_THRESHOLD_FLOOR=0

# MinIO object storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_BUCKET_NAME=recallix
MINIO_USE_SSL=false

# Asynq Concurrency
WORKER_CONCURRENCY=5
